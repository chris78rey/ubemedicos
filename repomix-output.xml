    cancelled_by_patient: 'grey',
    cancelled_by_professional: 'grey',
    completed: 'success',
    no_show_patient: 'error',
    no_show_professional: 'error',
  }

  return colors[value] || 'default'
}

const filteredPayments = computed(() => {
