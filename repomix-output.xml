                "reviewed_at": timezone.now(),
                "reviewer_notes": "Aprobación demo inicial.",
            },
        )

        demo_slots = [
            {"weekday": 0, "start_time": time(8, 0), "end_time": time(12, 0), "modality": AvailabilitySlot.Modality.IN_PERSON},
            {"weekday": 1, "start_time": time(14, 0), "end_time": time(18, 0), "modality": AvailabilitySlot.Modality.TELECONSULTATION},
            {"weekday": 3, "start_time": time(9, 0), "end_time": time(13, 0), "modality": AvailabilitySlot.Modality.IN_PERSON},
