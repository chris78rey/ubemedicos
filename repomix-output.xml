from django.core.exceptions import ValidationError
from django.test import TestCase
from django.contrib.auth import get_user_model

from apps.audits.models import AuditEvent
from apps.catalogs.models import Specialty
from .models import (
    ProfessionalProfile,
    ProfessionalDocument,
    ProfessionalVerificationSubmission,
    ProfessionalVerificationEvent,
)
from .services import submit_professional_for_verification


class ProfessionalVerificationSubmissionTests(TestCase):
    def setUp(self):
        self.User = get_user_model()

        self.admin_user = self.User.objects.create_user(
            email="admin@test.local",
            password="Admin123!",
            first_name="Admin",
            last_name="Test",
            role="admin",
            is_staff=True,
        )

        self.prof_user = self.User.objects.create_user(
            email="pro@test.local",
            password="Pro123456!",
            first_name="Ana",
            last_name="Ruiz",
            role="professional",
        )

        self.specialty = Specialty.objects.create(name="Medicina General")

        self.profile = ProfessionalProfile.objects.create(
            user=self.prof_user,
            specialty=self.specialty,
            license_number="LIC-123",
            city="Quito",
            province="Pichincha",
        )

    def _create_required_documents(self):
        ProfessionalDocument.objects.create(
            professional=self.profile,
            document_type=ProfessionalDocument.DocumentType.ID,
            file_path="/tmp/id.pdf",
            original_name="id.pdf",
        )
        ProfessionalDocument.objects.create(
            professional=self.profile,
            document_type=ProfessionalDocument.DocumentType.TITLE,
            file_path="/tmp/title.pdf",
            original_name="title.pdf",
        )
        ProfessionalDocument.objects.create(
            professional=self.profile,
            document_type=ProfessionalDocument.DocumentType.LICENSE,
            file_path="/tmp/license.pdf",
            original_name="license.pdf",
        )

    def test_submit_fails_when_required_documents_are_missing(self):
        with self.assertRaises(ValidationError):
            submit_professional_for_verification(
                professional=self.profile,
                actor=self.prof_user,
            )

        self.assertEqual(
            ProfessionalVerificationSubmission.objects.count(),
            0,
        )

    def test_submit_creates_submission_event_and_audit(self):
        self._create_required_documents()

        submission = submit_professional_for_verification(
            professional=self.profile,
            actor=self.prof_user,
        )

        self.profile.refresh_from_db()

        self.assertEqual(
            self.profile.verification_status,
            ProfessionalProfile.VerificationStatus.SUBMITTED,
        )
        self.assertFalse(self.profile.public_profile_enabled)
        self.assertEqual(
            submission.status,
            ProfessionalVerificationSubmission.Status.SUBMITTED,
        )
        self.assertEqual(ProfessionalVerificationSubmission.objects.count(), 1)
        self.assertEqual(ProfessionalVerificationEvent.objects.count(), 1)
        self.assertEqual(
            AuditEvent.objects.filter(
                event_type="professional_verification_submitted"
            ).count(),
            1,
        )

    def test_submit_fails_when_open_submission_already_exists(self):
        self._create_required_documents()

        submit_professional_for_verification(
            professional=self.profile,
            actor=self.prof_user,
        )

        with self.assertRaises(ValidationError):
            submit_professional_for_verification(
                professional=self.profile,
                actor=self.prof_user,
            )

        self.assertEqual(ProfessionalVerificationSubmission.objects.count(), 1)
